PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
DATABASE_URL=mysql://user:password@host:3306/database_name
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DATABASE_NAME=banpong_molly

# Mail (e.g. Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# จำนวนออเดอร์สูงสุดต่อรันของสคริปต์กวาดส่งใบเสร็จ (สูงสุด 5000 ต่อรอบตามเพดานในโค้ด)
RECEIPT_EMAIL_BATCH_LIMIT=5000

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRATION=7d
JWT_RESET_SECRET=your-reset-secret
JWT_RESET_EXPIRATION=1h

# Google OAuth (สำหรับ Login ด้วย Google - ใช้ Client ID จาก Google Cloud Console)
# ใช้แค่ GOOGLE_CLIENT_ID ก็เพียงพอ (สำหรับตรวจ id_token จากฝั่ง client)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_SCOPE=profile,email
